   "cell_type": "code",
   "execution_count": 44,
   "id": "2d4d7cf2",
   "metadata": {},
   "outputs": [],
   "source": [
    "def mv_norm(x, μ, Σ):\n",
    "  x = np.asarray(x)\n",
    "  μ = np.asarray(μ)\n",
    "  Σ = np.asarray(Σ)\n",
    "  \n",
    "  return ( np.linalg.det(2*np.pi*Σ)**(-0.5) * \n",
    "           np.exp(-0.5 * (x - μ).T @ np.linalg.solve(Σ, (x-μ)) ) )"
