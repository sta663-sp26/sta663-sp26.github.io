        "\n",
        "\n",
        "## Multivariate normal\n",
        "\n",
        "$$\n",
        "f(\\bf{x}) = \\det{(2\\pi\\Sigma)}^{-1/2} \\exp{\\left(-\\frac{1}{2} (\\bf{x}-\\mu)^T \\Sigma^{-1}(\\bf{x}-\\mu) \\right)}\n",
        "$$\n",
        "\n",
        "::: {.small}"
      ],
      "id": "4e6de160"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def mv_norm(x, μ, Σ):\n",
        "  x = np.asarray(x)\n",
        "  μ = np.asarray(μ)\n",
        "  Σ = np.asarray(Σ)\n",
        "  \n",
        "  return ( np.linalg.det(2*np.pi*Σ)**(-0.5) * \n",
        "           np.exp(-0.5 * (x - μ).T @ np.linalg.solve(Σ, (x-μ)) ) )"
      ],
      "id": "ebb170b7",
      "execution_count": null,
      "outputs": []
    },
