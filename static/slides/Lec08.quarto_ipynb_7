    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "n = 1000\n",
        "diagonals = [np.ones(n-1), -2*np.ones(n), np.ones(n-1)]\n",
        "A_sparse = sparse.diags(diagonals, [-1, 0, 1], format=\"csr\")\n",
        "b = np.ones(n)"
