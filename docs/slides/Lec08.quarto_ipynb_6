    "\n",
    "## Truncated normal PDF\n",
    "\n",
    "$$\n",
    "f(x) = \\begin{cases}\n",
    "\\frac{c}{\\sigma \\sqrt{2 \\pi}} \\exp\\left(-\\frac{1}{2} \\left(\\frac{x-\\mu}{\\sigma}\\right)^2  \\right), & \\text{for } a \\leq x \\leq b \\\\\n",
    "0,                                            & \\text{otherwise.} \\\\\n",
    "\\end{cases}\n",
    "$$\n",
    "\n",
    "::: {.small}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "62d8e1a8",
   "metadata": {},
   "outputs": [],
   "source": [
    "def trunc_norm_pdf(x, μ=0, σ=1, a=-np.inf, b=np.inf):\n",
    "  if (b < a):\n",
    "      raise ValueError(\"b must be greater than a\")\n",
    "\n",
    "  x = np.asarray(x)\n",
    "  scalar_input = x.ndim == 0\n",
    "  x = np.atleast_1d(x)\n",
    "\n",
    "  full_pdf = (1/(σ * np.sqrt(2*np.pi))) * np.exp(-0.5 * ((x - μ)/σ)**2)\n",
    "  full_pdf[(x < a) | (x > b)] = 0\n",
    "\n",
    "  return full_pdf[0] if scalar_input else full_pdf"
   ]
